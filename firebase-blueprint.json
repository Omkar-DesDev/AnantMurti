{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A handcrafted murti product.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "material": { "type": "string" },
        "size": { "type": "string" },
        "featured": { "type": "boolean" }
      },
      "required": ["name", "price", "category", "image"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "pincode": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["COD", "Online"] },
        "paymentId": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "phone", "address", "pincode", "items", "total", "paymentMethod"]
    },
    "User": {
      "title": "User",
      "description": "A customer profile.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "admin"] },
        "joinDate": { "type": "string", "format": "date-time" },
        "followers": { "type": "number" },
        "following": { "type": "number" }
      },
      "required": ["name", "email", "role"]
    }
  },
  "firestore": {
    "/products": {
      "schema": "Product",
      "description": "Collection of products."
    },
    "/orders": {
      "schema": "Order",
      "description": "Collection of orders."
    },
    "/users": {
      "schema": "User",
      "description": "Collection of user profiles."
    }
  }
}
